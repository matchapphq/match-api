{
  "name": "match-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "lint": "bunx eslint \"src/**/*.ts\"",
    "lint:fix": "bunx eslint \"src/**/*.ts\" --fix",
    "lint:commas": "bun run lint",
    "lint:commas:fix": "bun run lint:fix",
    "db:setup": "bun run src/config/setup.db.ts",
    "db:migrate": "bun run db:setup && drizzle-kit migrate",
    "db:migrate:dev": "bun run --env-file=.env.dev db:setup && drizzle-kit migrate --config=drizzle.config.dev.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "bun run db:setup && drizzle-kit push",
    "db:push:dev": "bun run --env-file=.env.dev db:setup && drizzle-kit push --config=drizzle.config.dev.ts",
    "db:seed:sports-only:dev": "bun run --env-file=.env.dev src/config/seeds/seed-sports-only.ts",
    "db:seed:matches": "bun run src/config/seeds/seed-matches-only.ts",
    "db:seed:matches:dev": "bun run --env-file=.env.dev src/config/seeds/seed-matches-only.ts",
    "db:seed:challenge": "bun run src/config/seeds/seed-challenge-rules.ts",
    "db:seed:challenge:dev": "bun run --env-file=.env.dev src/config/seeds/seed-challenge-rules.ts",
    "dev": "bun --env-file=.env.dev --watch index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/geolib": "^2.0.25",
    "@types/pg": "^8.15.5",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.38.0",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^1.0.2",
    "@types/nodemailer": "^7.0.4",
    "axios": "^1.13.2",
    "bullmq": "^5.66.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^5.0.0",
    "geolib": "^3.3.4",
    "handlebars": "^4.7.8",
    "hono": "^4.9.6",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.9.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "stripe": "^20.1.0",
    "zod": "^4.1.5"
  }
}
